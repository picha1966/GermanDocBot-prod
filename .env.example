# =============================================================================
# GERMAN_DOC_BOT — змінні оточення
# Скопіюйте цей файл в .env та підставте свої значення.
# =============================================================================
#
# Production: set ENV=production (or APP_ENV=production). Do NOT set
# STRIPE_ALLOW_UNVERIFIED_WEBHOOKS in production — the bot will refuse to start.
# ENV=production

# -----------------------------------------------------------------------------
# Telegram Bot (обов'язково)
# -----------------------------------------------------------------------------
# Токен від @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjkLmnOPQrstUVwxyz

# Username бота без @ (як у посиланні t.me/Deutschland_PDF_bot)
BOT_USERNAME=Deutschland_PDF_bot

# Посилання на ваш сайт (відображається кнопкою "Website" після PDF)
# Якщо порожньо — кнопка не показується
WEBSITE_URL=https://your-site.com

# -----------------------------------------------------------------------------
# WebApp (обов'язково для форми в боті)
# -----------------------------------------------------------------------------
# Публічний URL, куди Telegram відкриває форму (production HTTPS).
# 1) Запустіть: python bot.py
# 2) Вставте сюди ваш production URL (без слеша в кінці)
WEBAPP_URL=https://termin-assist.de/form

# -----------------------------------------------------------------------------
# Адмін (опційно)
# -----------------------------------------------------------------------------
# Ваш Telegram user ID (одне число або кілька через кому). Для /admin та сповіщень.
# Як дізнатися ID: напишіть боту @userinfobot
ADMIN_IDS=123456789

# -----------------------------------------------------------------------------
# Stripe — оплата (обов'язково для Termin Checkout, Stage 17)
# -----------------------------------------------------------------------------
# Секретний ключ: https://dashboard.stripe.com/test/apikeys
# REQUIRED for Termin reservation payments (Stage 17). Without this key,
# Stripe Checkout session creation will fail.
STRIPE_API_KEY=YOUR_STRIPE_SECRET_KEY
# Webhook: Stripe Dashboard → Developers → Webhooks → Add endpoint →
#   URL: https://YOUR_DOMAIN/stripe-webhook
#   Event: checkout.session.completed
# REQUIRED in production. POST /stripe-webhook returns 503 if missing unless dev override below.
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET
# Local Stripe CLI / testing ONLY — never enable in production (accepts unsigned JSON).
# STRIPE_ALLOW_UNVERIFIED_WEBHOOKS=true

# -----------------------------------------------------------------------------
# Termin — перевірка доступності (опційно)
# -----------------------------------------------------------------------------
# URL зовнішнього API для перевірки вільних місць.
# Якщо не вказано — використовується вбудований stub (~20% випадкової доступності).
# API contract: GET {URL}?city=...&authority=... → 200 {"available": true/false}
# TERMIN_API_URL=https://your-termin-api.example.com/check

# Redis (опційно — Stage 15)
# Якщо не вказано — стан зберігається лише в пам'яті процесу.
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Email доставка PDF після оплати (обирайте один із трьох провайдерів)
# =============================================================================
# Відправник — відображається у полі «From» листа
# Формат: "CivicAssistBot <noreply@yourdomain.com>"
EMAIL_FROM=CivicAssistBot <noreply@yourdomain.com>

# Встановіть 0, щоб повністю вимкнути email-доставку
# EMAIL_ENABLED=1

# --- Варіант 1: SendGrid (рекомендовано для production) ---
# Реєстрація: https://sendgrid.com/ → API Keys → Full Access
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# --- Варіант 2: Resend (сучасний API, простий DNS) ---
# Реєстрація: https://resend.com/ → API Keys
# Встановлення: pip install resend
# RESEND_API_KEY=re_xxxxxxxxxxxx

# --- Варіант 3: SMTP (будь-який SMTP-сервер) ---
# Gmail: host=smtp.gmail.com, port=587, user=your@gmail.com, pass=app-password
# Mailgun: host=smtp.mailgun.org, port=587
# Постой SMTP: host=mail.yourdomain.com, port=587
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=noreply@yourdomain.com
# EMAIL_SMTP_PASS=your_app_password_here

# =============================================================================
# AI Support (опційно — handlers/support_ai)
# =============================================================================
# OpenAI API key для вбудованого AI-асистента у чаті підтримки.
# Якщо не вказано — AI-відповіді вимкнені, бот повертає стандартний текст.
# OPENAI_API_KEY=sk-...

# =============================================================================
# Throttling (опційно — за замовчуванням 1 msg/s і 2 callbacks/s)
# =============================================================================
# Максимальна кількість повідомлень в секунду на одного користувача
# THROTTLE_MSG_RATE=1
# Максимальна кількість callback-запитів в секунду на одного користувача
# THROTTLE_CB_RATE=2

# =============================================================================
# Додаткові змінні (потрібні лише якщо запускаєте окремо webapp_server.py)
# =============================================================================
# BOT_WEBAPP_SUBMIT_URL=http://127.0.0.1:4243/webapp-submit
# WEBAPP_PORT=4242
